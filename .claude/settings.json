{
  "permissions": {
    "allow": [
      "Bash(curl -s * data.elexon.co.uk*)",
      "Bash(systemctl --user status *)",
      "Bash(systemctl --user is-active *)",
      "Bash(journalctl --user-unit * *)",
      "Bash(make test)",
      "Bash(make lint)",
      "Bash(python3 -m tools.epistemic_verifier)",
      "Bash(git pull*)",
      "Bash(git fetch*)"
    ]
  },
  "fallbackModel": ["claude-sonnet-5", "claude-haiku-4-5-20251001"],
  "env": {
    "//": "REST HEARTBEAT (LOOP_CONTINUITY_REARM_DESIGN.md, 2026-07-19): the drained-and-gated Stop hook now keeps the worker's turn-chain alive with a bounded in-hook poll + keep-alive continuations. Claude Code force-stops a Stop hook after 8 consecutive no-progress blocks; a resting heartbeat is 'no progress' by design, so raise the built-in cap. The pull-loop's own git-based MAX_NO_PROGRESS (background-checked) stays the REAL runaway guard for PRODUCTIVE chains; heartbeats are exempt from it by construction. Console-agnostic (only the worker seat heartbeats).",
    "CLAUDE_CODE_STOP_HOOK_BLOCK_CAP": "100000"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/block_sudo.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/block_unevidenced_claim.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/block_point_in_time_read.py"
          }
        ]
      },
      {
        "matcher": "Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/lane_wall_hook.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/log_director_input.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/stamp_human_presence.py"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "path_glob_match",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/log_instructions_loaded.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pull_next_work.py",
            "timeout": 600
          }
        ]
      }
    ]
  }
}