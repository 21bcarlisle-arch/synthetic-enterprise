#!/bin/sh
# If docs/status/LATEST.md is staged, auto-stamp its "Last updated:" line to
# the current UTC time and re-stage it. This makes the timestamp a fact about
# when the commit happened rather than something a human/agent has to
# remember to edit by hand (see tools/stamp_latest_md.py for the why).
if git diff --cached --name-only | grep -qx "docs/status/LATEST.md"; then
    python3 tools/stamp_latest_md.py && git add docs/status/LATEST.md
    # STATUS HONESTY (director P0, step 5): a LATEST.md that describes a non-running daemon or a
    # retired governance model as CURRENT must not be committed. The stale narrative, re-stamped
    # fresh each publish, made the director misread the whole system as breached. Refuse the commit
    # (structural) -- fix the header to declared truth first.
    python3 -m background.status_honesty || {
        echo "[status-honesty] LATEST.md describes a non-running system -- COMMIT REFUSED. Fix the header to declared truth." >&2
        exit 1
    }
fi

# TEST GATE (director P0, 2026-07-17): a commit with red tests is STRUCTURALLY IMPOSSIBLE, not
# merely discouraged -- structural impossibility over remembered discipline (two red commits
# landed tonight because "run tests then commit" is a remembered process, and remembered processes
# are what failed). Protects the integrity of the parallel-safety controls being built with an
# autonomously-committing loop: a subtly-broken control can never land looking green. Runs the
# safety-control set + the tests for each changed code file; any failure ABORTS the commit.
python3 tools/pre_commit_test_gate.py || exit 1

# §0 LEVEL-PROMOTION PREVENTION GATE (2026-07-18): an UNAUTHORIZED level_current increase in
# docs/design/maturity_map.yaml is STRUCTURALLY IMPOSSIBLE to commit. The director+advisor own
# levels; the agent PROPOSES with evidence and never moves a cell (MATURITY_MAP.md §0). The
# fronts_reconciler DETECTS a self-move after the fact; this REFUSES the commit at write time so a
# false level can never render on the director's site. Reuses gate_authorization.is_valid_level_up
# (the same predicate the reconciler uses); a level decrease/revert and non-map commits are never
# blocked. Real incident: the worker self-moved E4 level_current 2->3 in its own commit.
python3 tools/level_promotion_gate.py || exit 1

# SITE-LANE GATE (Campaign A debt E, 2026-07-19, SITE_TEST_COVERAGE_SEAM_FRAME.md): the publish gate
# (process_run_complete, test_root="tests/") is BLIND to site/**, so a red site-door test cannot
# wedge it and slips onto the director's window (happened 3x this session). This runs `pytest site/`
# (or the sibling site tests for a direct edit) whenever the change touches site/**, site/data/**, a
# generate_*_data producer, or a site-consumed ledger -- an ISOLATED step (its own alarm) that never
# touches the tests/ publish gate. Fails closed if node is missing (the .mjs render harnesses would
# silently skip). R15-proven in tests/tools/test_site_lane_gate.py.
python3 tools/site_lane_gate.py || exit 1
